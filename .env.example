# ========================
# Database
# ========================
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/repair_system_db"

# ========================
# JWT
# ========================
JWT_SECRET="replace-with-a-long-random-secret"

# ========================
# Server
# ========================
PORT=3000

# CORS — ถ้าใช้ frontend คนละ origin ให้ระบุ URL ของ frontend ที่นี่
CORS_ORIGIN=http://localhost:5173

# ========================
# SMTP Email (Nodemailer)
# ========================
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Test (Ethereal — ไม่ส่งจริง): https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-or-gmail-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="ระบบแจ้งซ่อม" <no-reply@repair.local>
