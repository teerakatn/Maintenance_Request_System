# ========================
# Database
# ========================
# Neon pooled connection (runtime)
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLED-HOST/neondb?sslmode=require&pgbouncer=true"
# Neon direct connection (schema operations)
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST/neondb?sslmode=require"

# ========================
# JWT
# ========================
JWT_SECRET="replace-with-a-long-random-secret"

# ========================
# Server
# ========================
PORT=3000

# CORS — local dev / production frontend URL
CORS_ORIGIN=http://localhost:3000

# ========================
# SMTP Email (Nodemailer)
# ========================
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Test (Ethereal — ไม่ส่งจริง): https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-or-gmail-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="ระบบแจ้งซ่อม" <no-reply@repair.local>
